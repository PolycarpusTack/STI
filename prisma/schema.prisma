generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Issue {
  id            String   @id @default(cuid())
  sentryIssueId String   @unique
  projectId     String
  fingerprint   String
  title         String
  level         String   @default("error")
  status        String   @default("unresolved")
  environment   String   @default("production")
  release       String?
  eventCount    Int      @default(1)
  firstSeen     DateTime
  lastSeen      DateTime
  culprit       String   @default("")
  stacktrace    String?
  tags          String   @default("{}")
  statsJson     String?
  brief         Brief?
  decisions     Decision[]
  suppressions  Suppression[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([fingerprint])
  @@index([lastSeen])
  @@index([level])
  @@index([projectId])
}

model Brief {
  id               String   @id @default(cuid())
  issueId          String   @unique
  issue            Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  promptVersion    String   @default("v0.4.0")
  lean             String   @default("investigate")
  confidence       Float    @default(0.5)
  priority         String   @default("")
  issueType        String   @default("")
  summary          String
  module           String   @default("")
  tenantImpact     String   @default("")
  reproductionHint String?
  confidenceNotes  String?
  signals          String?
  rawResponse      String   @default("")
  parseError       Boolean  @default(false)
  tokenCount       Int?
  latencyMs        Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([lean])
}

model Decision {
  id               String   @id @default(cuid())
  issueId          String
  issue            Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  briefId          String?
  decision         String
  aiLean           String?
  responderId      String   @default("responder-1")
  jiraId           String?
  jiraKey          String?
  jiraSummary      String?
  jiraDescription  String?
  jiraPriority     String?
  jiraComponent    String?
  jiraError        String?
  suppressReason   String?
  suppressScope    String?
  suppressed       Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([issueId])
  @@index([decision])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Suppression {
  id            String    @id @default(cuid())
  fingerprint   String
  reason        String    @default("")
  scope         String    @default("global")
  tenantValue   String?
  authorId      String    @default("system")
  createdAt     DateTime  @default(now())
  lastMatchedAt DateTime?
  issues        Issue[]

  @@index([fingerprint])
}

model SentryProject {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String   @default("")
  createdAt DateTime @default(now())
}

model TeamRole {
  id        String       @id @default(cuid())
  name      String       @unique
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  members   TeamMember[]
  entries   RotaEntry[]
}

model TeamMember {
  id            String      @id @default(cuid())
  name          String
  defaultRoleId String?
  defaultRole   TeamRole?   @relation(fields: [defaultRoleId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  entries       RotaEntry[]
}

model WeeklyRota {
  id        String      @id @default(cuid())
  isoYear   Int
  isoWeek   Int
  notes     String      @default("")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  entries   RotaEntry[]

  @@unique([isoYear, isoWeek])
}

model RotaEntry {
  id       String     @id @default(cuid())
  rotaId   String
  rota     WeeklyRota @relation(fields: [rotaId], references: [id], onDelete: Cascade)
  roleId   String
  role     TeamRole   @relation(fields: [roleId], references: [id])
  memberId String
  member   TeamMember @relation(fields: [memberId], references: [id])

  @@unique([rotaId, roleId])
}
