DATABASE_URL=file:C:/Projects/STI/db/custom.db

# ── Dev helpers ───────────────────────────────────────────────────────────────
SEED_ENABLED=true

# ── Sentry pipeline ──────────────────────────────────────────────────────────
SENTRY_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Poller ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_MINUTES=10
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── LLM runtime (overridden by Settings UI; fallback to .z-ai-config) ────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o

# ── Jira integration (overridden by Settings UI) ──────────────────────────────
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_KEY=
JIRA_PROJECT_KEY=
